{
  "name": "ozledger-local",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "build:server": "node --check server/index.js && node --check server/db.js && node --check server/sqlite-db.js && node --check server/mysql-db.js && node --check server/seed.js",
    "preview": "vite preview",
    "serve": "serve -s dist -l 3000",
    "start": "node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "lucide-react": "^0.344.0",
    "mysql2": "^3.22.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "serve": "^14.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
